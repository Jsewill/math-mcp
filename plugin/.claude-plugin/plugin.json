{
  "name": "math-mcp",
  "version": "0.4.0",
  "description": "Routing enforcement for math-mcp — PreToolUse:Bash intercepts shell calculators, SessionStart injects a terse routing cheat sheet, plus a trigger-phrase skill and /math-verify slash command.",
  "author": {
    "name": "Abraham Sewill",
    "email": "abraham.sewill@proton.me",
    "url": "https://github.com/Jsewill"
  },
  "homepage": "https://github.com/Jsewill/math-mcp",
  "repository": "https://github.com/Jsewill/math-mcp",
  "license": "MIT",
  "keywords": ["math", "sympy", "mcp", "routing", "arithmetic", "precision"],
  "mcpServers": {
    "math-mcp": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/Jsewill/math-mcp", "sympy-math-mcp"],
      "env": {
        "GIT_CONFIG_COUNT": "1",
        "GIT_CONFIG_KEY_0": "init.defaultObjectFormat",
        "GIT_CONFIG_VALUE_0": "sha1"
      }
    }
  },
  "skills": "./skills/"
}
